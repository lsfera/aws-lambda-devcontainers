# Template for .devcontainer/.env
# .env is generated automatically by init.sh / build.sh — do not commit it.
# Copy this file to .env and adjust if you want non-default values.

# Absolute path to your AWS credentials and config on the host.
# Bind-mounted read-write into every container — never copied into any image.
# Override if your credentials live elsewhere (e.g. a secrets manager sidecar).
AWS_CONFIG_DIR=/Users/CHANGE_ME/.aws

# Absolute path to your SSH keys on the host.
# Bind-mounted read-only for private git submodule access.
# System-wide known_hosts (github.com, gitlab.com, bitbucket.org) are baked into
# the image, so the mount can stay read-only even on first clone.
SSH_DIR=/Users/CHANGE_ME/.ssh

# Absolute path on the host where Claude Code config and data are persisted.
# Shared across all devcontainer variants (base, csharp, ...).
# Contains:
#   claude.json  — MCP server registrations, user settings
#   data/        — memory files, project history, conversation state
# Default generated by init.sh: $HOME/.devcontainer-claude
CLAUDE_PERSIST_HOST_DIR=/Users/CHANGE_ME/.devcontainer-claude

# Docker socket path.
# Standard Docker Desktop (macOS/Windows/Linux): /var/run/docker.sock
# Rootless Docker on Linux: /run/user/1000/docker.sock  (replace 1000 with your UID)
DOCKER_SOCK=/var/run/docker.sock

# GID the container user joins to reach the Docker socket (docker-out-of-docker).
# Must match the socket's group *as seen inside the container*, not the host
# group name:
#   - Docker Desktop (macOS/Windows): mounted socket is root:root group-rw → 0
#   - Native Linux (rootful): the host "docker" group GID, e.g.
#       stat -c '%g' /var/run/docker.sock
# init.sh auto-detects this; override only for non-standard setups.
DOCKER_GID=0

# Tag for the base image (built by build.sh, extended by language Dockerfiles)
BASE_IMAGE=aws-lambda-base:latest

# .NET SDK major version for the C# devcontainer
DOTNET_VERSION=9.0

# Python version for the Python devcontainer (must match an active Lambda runtime)
# Supported: 3.13 (default), 3.12, 3.11
PYTHON_VERSION=3.13

# ── Shared dependency caches ──────────────────────────────────────────────────
# Host directories bind-mounted into the language variants at each tool's default
# cache/store location, so package downloads are shared across every project and
# container and survive rebuilds. Default under $HOME/.devcontainer-cache.
NPM_CACHE_HOST_DIR=/Users/CHANGE_ME/.devcontainer-cache/npm      # → /home/vscode/.npm
PNPM_STORE_HOST_DIR=/Users/CHANGE_ME/.devcontainer-cache/pnpm    # → ~/.local/share/pnpm/store
UV_CACHE_HOST_DIR=/Users/CHANGE_ME/.devcontainer-cache/uv        # → /home/vscode/.cache/uv
NUGET_HOST_DIR=/Users/CHANGE_ME/.devcontainer-cache/nuget        # → /home/vscode/.nuget/packages
